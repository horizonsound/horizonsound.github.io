---
const menu = [
  { href: "/", label: "On Stage" },
  { href: "/catalog", label: "Explorer" },
  { href: "/artists", label: "Artists" },
  { href: "/origins", label: "Origins" },
];
---

<header class="site-header">
  <div class="site-header-top">
    <div class="branding">
      <img src="/assets/horizon-logo.svg" class="logo" alt="Horizon Sound Logo" />
      <h1>Horizon Sound</h1>
    </div>

    <div id="autoplay-toggle" class="autoplay-toggle">
      <span class="icon"></span>
    </div>
  </div>

  <nav class="main-nav">
    <ul>
      {menu.map(item => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("autoplay-toggle");
    if (!toggle) return;

    const icon = toggle.querySelector(".icon")!;

    function updateIcon() {
      icon.textContent = window.autoplay?.enabled ? "🔊" : "🔇";
    }

    toggle.addEventListener("click", () => {
      window.autoplay = window.autoplay || {};
      window.autoplay.enabled = !window.autoplay.enabled;
      updateIcon();
    });

    updateIcon();
  });
</script>