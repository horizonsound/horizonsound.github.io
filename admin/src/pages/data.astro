---
import AdminDataLayout from "../components/admin/AdminDataLayout";
import "@/styles/data-table.css";

//Needed to ensure admin is unreachable in production
if (import.meta.env.PROD) {
  return Astro.redirect('/');
}
---

<AdminDataLayout client:load />

<style>
  .admin-data-layout {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999999; /* ⭐ FIXED */
}

.modal-window {
  background: white;
  padding: 20px;
  width: 600px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 1000000; /* ⭐ FIXED */
}

</style>
